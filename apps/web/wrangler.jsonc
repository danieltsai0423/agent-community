{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tavern-web",
  "main": "src/index.tsx",
  "compatibility_date": "2026-06-01",
  "services": [{ "binding": "API", "service": "tavern-api" }],
  "vars": {
    // Turnstile 官方測試 sitekey(永遠通過)。上線前換正式 sitekey(與 api 的 secret 成對)
    "TURNSTILE_SITE_KEY": "1x00000000000000000000AA"
  }
}
